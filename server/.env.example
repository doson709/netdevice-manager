# NetDevice Manager Configuration Template
# Sao chép file này thành .env và cập nhật thông tin cấu hình của bạn.

# Tài khoản quản trị Admin (Frontend Login)
NETDEVICE_ADMIN_USERNAME=admin
NETDEVICE_ADMIN_PASSWORD=your_secure_password_here
NETDEVICE_ADMIN_TOKEN=your_secure_admin_token_here

# Mã khóa token bảo mật phía server (xác thực Agent gửi báo cáo)
NETDEVICE_SECRET_TOKEN=your_secure_secret_token_here
